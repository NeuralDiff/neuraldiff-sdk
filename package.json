{
  "name": "@neuraldiff/sdk",
  "version": "1.0.0",
  "description": "NeuralDiff SDK for AI-powered visual regression testing",
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "build:watch": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage .nyc_output",
    "version:patch": "node scripts/version.js patch",
    "version:minor": "node scripts/version.js minor",
    "version:major": "node scripts/version.js major",
    "version:custom": "node scripts/version.js custom",
    "prepublishOnly": "npm run build && npm run test && npm run lint",
    "publish:latest": "node scripts/publish.js latest",
    "publish:beta": "node scripts/publish.js beta",
    "publish:alpha": "node scripts/publish.js alpha",
    "release": "npm run version:patch && npm run publish:latest",
    "release:minor": "npm run version:minor && npm run publish:latest",
    "release:major": "npm run version:major && npm run publish:latest",
    "release:beta": "npm run version:patch && npm run publish:beta",
    "release:alpha": "npm run version:patch && npm run publish:alpha"
  },
  "keywords": [
    "visual-regression",
    "testing",
    "ai",
    "screenshot",
    "ui-testing",
    "neuraldiff",
    "automation"
  ],
  "author": "NeuralDiff Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/neuraldiff/neuraldiff-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/neuraldiff/neuraldiff-sdk/issues"
  },
  "homepage": "https://neuraldiff.com",
  "engines": {
    "node": ">=16.0.0"
  },
  "peerDependencies": {
    "playwright": ">=1.40.0",
    "react": ">=16.8.0",
    "vue": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "playwright": {
      "optional": true
    }
  },
  "dependencies": {
    "axios": "^1.6.0",
    "p-limit": "^5.0.0",
    "ws": "^8.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.8.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "@vitest/coverage-v8": "^0.34.0",
    "eslint": "^8.50.0",
    "playwright": "^1.58.2",
    "rimraf": "^5.0.0",
    "sharp": "^0.34.5",
    "tsup": "^7.2.0",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  }
}
