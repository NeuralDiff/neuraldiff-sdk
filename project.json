{
  "name": "neuraldiff-sdk",
  "$schema": "../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "neuraldiff-sdk/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "tsup src/index.ts --format cjs,esm --dts --clean",
        "cwd": "neuraldiff-sdk"
      }
    },
    "build:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsup src/index.ts --format cjs,esm --dts --watch",
        "cwd": "neuraldiff-sdk"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "command": "vitest run",
        "cwd": "neuraldiff-sdk"
      }
    },
    "test:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest",
        "cwd": "neuraldiff-sdk"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --coverage",
        "cwd": "neuraldiff-sdk"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["neuraldiff-sdk/**/*.ts"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "neuraldiff-sdk"
      }
    },
    "publish": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "test", "lint"],
      "options": {
        "command": "npm publish",
        "cwd": "neuraldiff-sdk"
      }
    },
    "publish:beta": {
      "executor": "nx:run-commands",
      "dependsOn": ["build", "test", "lint"],
      "options": {
        "command": "npm publish --tag beta",
        "cwd": "neuraldiff-sdk"
      }
    }
  },
  "tags": ["scope:sdk", "type:lib", "publishable"]
}